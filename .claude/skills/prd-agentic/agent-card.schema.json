{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PRD Agent Card (A2A)",
  "description": "A2A skill-card describing a Betterworks PRD as an addressable agent skill. Static v1 — file is emitted at draft time; no live endpoint.",
  "type": "object",
  "required": ["name", "description", "url", "version", "capabilities", "skills"],
  "properties": {
    "name": { "type": "string", "pattern": "^prd-[a-z0-9-]+$" },
    "description": { "type": "string", "minLength": 10 },
    "url": { "type": "string", "format": "uri-reference" },
    "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "capabilities": {
      "type": "object",
      "required": ["streaming", "pushNotifications", "stateTransitionHistory"],
      "properties": {
        "streaming": { "type": "boolean" },
        "pushNotifications": { "type": "boolean" },
        "stateTransitionHistory": { "type": "boolean" }
      }
    },
    "skills": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "description"],
        "properties": {
          "id": { "type": "string" },
          "description": { "type": "string" },
          "inputSchema": { "type": "object" }
        }
      }
    },
    "sections": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["anchor", "type", "id"],
        "properties": {
          "anchor": { "type": "string", "pattern": "^#[a-z0-9-]+$" },
          "type": { "type": "string", "enum": ["capability", "user-story", "acceptance-criterion", "constraint", "definition-of-done"] },
          "id": { "type": "string" }
        }
      }
    }
  }
}
